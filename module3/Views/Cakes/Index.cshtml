@model IEnumerable<CakeShop.Models.Cake>

<h2>Торты</h2>

<a asp-action="Create" class="btn btn-success">
    Добавить
</a>

<table class="table">

    <tr>

        <th>Название</th>

        <th>Тип</th>

        <th>Цена</th>

        <th></th>

    </tr>

@foreach(var item in Model)
{
<tr>

<td>@item.Name</td>

<td>@item.Type</td>

<td>@item.Price</td>

<td>

<a asp-action="Edit" asp-route-id="@item.Id">
Редактировать
</a>

|

<a asp-action="Delete" asp-route-id="@item.Id">
Удалить
</a>

</td>

</tr>
}

</table>